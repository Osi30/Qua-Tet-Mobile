<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutBottomNav"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:background="@android:color/white"
    android:elevation="12dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="6dp"
    android:paddingTop="8dp"
    android:paddingEnd="6dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/navStoreLocation"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavStoreLocation"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_location"
            app:tint="#B0B0B0" />

        <TextView
            android:id="@+id/tvNavStoreLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Vị trí"
            android:textColor="#B0B0B0"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navCart"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavCart"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_cart"
            app:tint="#B0B0B0" />

        <TextView
            android:id="@+id/tvNavCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Giỏ hàng"
            android:textColor="#B0B0B0"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:id="@+id/viewNavHomeBg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/bg_nav_home_active" />

            <ImageView
                android:id="@+id/ivNavHome"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="-42dp"
                android:src="@drawable/ic_nav_home"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Cửa hàng"
                android:textColor="#8B0000"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/navOrderHistory"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavOrderHistory"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="#B0B0B0" />

        <TextView
            android:id="@+id/tvNavOrderHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Lịch sử"
            android:textColor="#B0B0B0"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navUser"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavUser"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_user"
            app:tint="#B0B0B0" />

        <TextView
            android:id="@+id/tvNavUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Tài khoản"
            android:textColor="#B0B0B0"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
